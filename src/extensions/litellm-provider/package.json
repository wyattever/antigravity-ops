{
  "name": "litellm-provider",
  "displayName": "LiteLLM Provider",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "antigravity-explorer",
          "title": "Antigravity",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "antigravity-explorer": [
        {
          "type": "webview",
          "id": "acpSidebar",
          "name": "Control Plane",
          "visibility": "visible",
          "icon": "$(dashboard)"
        }
      ]
    },
    "commands": [
      {
        "command": "ask.antigravity",
        "title": "Ask Antigravity (ACP)"
      },
      {
        "command": "panic.rollback",
        "title": "🚨 ACP: Rollback Workspace"
      }
    ]
  }
}
